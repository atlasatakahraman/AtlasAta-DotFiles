{
    "cursor.composer.textSizeScale": 1.3,
    "cursor.composer.queueMessageDefaultBehavior": "stop-and-send",
    "cursor.cpp.enablePartialAccepts": true,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.fontFamily": "CaskaydiaCove NF",
    "cursor.general.glassShowWarningNotifications": true,
    "cursor.terminal.usePreviewBox": true,
    "editor.autoClosingBrackets": "always",
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "workbench.iconTheme": "pierre-icons-complete",
    "workbench.colorTheme": "Claude Dark",
    "terminal.integrated.mouseWheelZoom": true,
    "explorer.confirmPasteNative": false,
    "explorer.confirmDelete": false,
    "editor.fastScrollSensitivity": 7,
    "editor.mouseWheelScrollSensitivity": 2,
    "javascript.preferences.importModuleSpecifier": "non-relative",
    "javascript.updateImportsOnPaste.enabled": true,
    "typescript.preferences.preferTypeOnlyAutoImports": true,
    "typescript.updateImportsOnPaste.enabled": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "editor.codeActionsOnSave": {
        "source.sortImports": "always",
        "source.addMissingImports.ts": "always",
        "source.fixAll.ts": "always",
        "source.removeUnusedImports": "always"
    },
    "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
    "javascript.inlayHints.parameterTypes.enabled": true,
    "javascript.preferences.importModuleSpecifierEnding": "minimal",
    "typescript.preferences.importModuleSpecifier": "non-relative",
    "typescript.preferences.importModuleSpecifierEnding": "minimal",
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "typescript.format.placeOpenBraceOnNewLineForFunctions": true,
    "typescript.format.placeOpenBraceOnNewLineForControlBlocks": true,
    "javascript.format.placeOpenBraceOnNewLineForFunctions": true,
    "javascript.format.placeOpenBraceOnNewLineForControlBlocks": true,
    "window.zoomLevel": 1,
    "explorer.confirmDragAndDrop": false,
    "typescript.updateImportsOnFileMove.enabled": "always"
}