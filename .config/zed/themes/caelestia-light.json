{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Caelestia Light",
  "author": "AtlasAta",
  "themes": [
    {
      "name": "Caelestia Light",
      "appearance": "light",
      "style": {
        "border":                           "#ccc6bb",
        "border.variant":                   "#e6e2df",
        "border.focused":                   "#3b3628",
        "border.selected":                  "#3b3628",
        "border.transparent":               "#00000000",
        "border.disabled":                  "#e6e2df",
        "elevated_surface.background":      "#fdf8f5",
        "surface.background":               "#f7f3f0",
        "background":                       "#fdf8f5",
        "element": {
          "background": "#f2edea",
          "hover":      "#ece7e4",
          "active":     "#e8e2d7",
          "selected":   "#e8e2d7",
          "disabled":   "#f2edea"
        },
        "ghost_element": {
          "background": "#00000000",
          "hover":      "#f2edea80",
          "active":     "#e8e2d780",
          "selected":   "#e8e2d780",
          "disabled":   "#f2edea80"
        },
        "drop_target.background":           "#3b362840",
        "text":                             "#1c1b1a",
        "text.muted":                       "#7b776d",
        "text.placeholder":                 "#ada9a2",
        "text.disabled":                    "#ada9a2",
        "text.accent":                      "#3b3628",
        "icon":                             "#4a473e",
        "icon.muted":                       "#ada9a2",
        "icon.disabled":                    "#ada9a2",
        "icon.placeholder":                 "#ada9a2",
        "icon.accent":                      "#3b3628",
        "status_bar.background":            "#f2edea",
        "title_bar.background":             "#f2edea",
        "title_bar.inactive_background":    "#f7f3f0",
        "toolbar.background":               "#f2edea",
        "tab_bar.background":               "#f2edea",
        "tab.inactive_background":          "#f2edea",
        "tab.active_background":            "#fdf8f5",
        "search.match_background":          "#c5aa3d50",
        "panel.background":                 "#f7f3f0",
        "panel.focused_border":             "#3b3628",
        "pane.focused_border":              "#3b3628",
        "scrollbar.thumb.background":       "#ccc6bb80",
        "scrollbar.thumb.hover_background": "#7b776d80",
        "scrollbar.thumb.border":           "#00000000",
        "scrollbar.track.background":       "#00000000",
        "scrollbar.track.border":           "#00000000",
        "editor.foreground":                "#1c1b1a",
        "editor.background":                "#fdf8f5",
        "editor.gutter.background":         "#fdf8f5",
        "editor.subheader.background":      "#f7f3f0",
        "editor.active_line.background":    "#f2edea",
        "editor.highlighted_line.background": "#f2edea",
        "editor.line_number":               "#ada9a2",
        "editor.active_line_number":        "#7b776d",
        "editor.invisible":                 "#ccc6bb",
        "editor.wrap_guide":                "#e6e2df",
        "editor.active_wrap_guide":         "#ccc6bb",
        "editor.document_highlight.read_background":  "#c5aa3d25",
        "editor.document_highlight.write_background": "#c5aa3d45",
        "link_text.hover":                  "#00664e",
        "conflict":             "#9b782c",
        "conflict.background":  "#9b782c20",
        "conflict.border":      "#9b782c",
        "created":              "#4b882e",
        "created.background":   "#4b882e20",
        "created.border":       "#4b882e",
        "deleted":              "#ba1a1a",
        "deleted.background":   "#ba1a1a20",
        "deleted.border":       "#ba1a1a",
        "error":                "#ba1a1a",
        "error.background":     "#ba1a1a20",
        "error.border":         "#ba1a1a",
        "hidden":               "#ada9a2",
        "hidden.background":    "#fdf8f5",
        "hidden.border":        "#ccc6bb",
        "hint":                 "#4b882e",
        "hint.background":      "#4b882e20",
        "hint.border":          "#4b882e",
        "ignored":              "#ada9a2",
        "ignored.background":   "#fdf8f5",
        "ignored.border":       "#ccc6bb",
        "info":                 "#00664e",
        "info.background":      "#00664e20",
        "info.border":          "#00664e",
        "modified":             "#9b782c",
        "modified.background":  "#9b782c20",
        "modified.border":      "#9b782c",
        "predictive":           "#7b776d",
        "predictive.background": "#f2edea",
        "predictive.border":    "#ccc6bb",
        "renamed":              "#636e1c",
        "renamed.background":   "#636e1c20",
        "renamed.border":       "#636e1c",
        "success":              "#4b882e",
        "success.background":   "#4b882e20",
        "success.border":       "#4b882e",
        "unreachable":          "#ada9a2",
        "unreachable.background": "#fdf8f5",
        "unreachable.border":   "#ccc6bb",
        "warning":              "#9b782c",
        "warning.background":   "#9b782c20",
        "warning.border":       "#9b782c",
        "players": [
          { "cursor": "#625e56", "background": "#625e56", "selection": "#625e5640" },
          { "cursor": "#9b782c", "background": "#9b782c", "selection": "#9b782c40" },
          { "cursor": "#4b882e", "background": "#4b882e", "selection": "#4b882e40" },
          { "cursor": "#00664e", "background": "#00664e", "selection": "#00664e40" },
          { "cursor": "#636e1c", "background": "#636e1c", "selection": "#636e1c40" },
          { "cursor": "#8f3b00", "background": "#8f3b00", "selection": "#8f3b0040" }
        ],
        "syntax": {
          "attribute":              { "color": "#9a7a00" },
          "boolean":                { "color": "#8f3b00", "font_weight": 700 },
          "comment":                { "color": "#7b776d", "font_style": "italic" },
          "comment.doc":            { "color": "#4a473e", "font_style": "italic" },
          "constant":               { "color": "#8f3b00", "font_weight": 700 },
          "constructor":            { "color": "#00664e", "font_weight": 700 },
          "embedded":               { "color": "#1c1b1a" },
          "emphasis":               { "font_style": "italic" },
          "emphasis.strong":        { "font_weight": 700 },
          "enum":                   { "color": "#636e1c", "font_weight": 700 },
          "function":               { "color": "#4b882e", "font_weight": 700 },
          "function.method":        { "color": "#4b882e", "font_weight": 700 },
          "hint":                   { "color": "#4b882e", "font_style": "italic", "font_weight": 700 },
          "keyword":                { "color": "#3b3628", "font_weight": 700 },
          "label":                  { "color": "#625e56" },
          "link_text":              { "color": "#00664e", "font_style": "italic" },
          "link_uri":               { "color": "#00664e" },
          "number":                 { "color": "#9b782c" },
          "operator":               { "color": "#625e56", "font_weight": 700 },
          "predictive":             { "color": "#7b776d", "font_style": "italic" },
          "preproc":                { "color": "#8f3b00", "font_weight": 700 },
          "primary":                { "color": "#1c1b1a" },
          "property":               { "color": "#4a473e" },
          "punctuation":            { "color": "#9c9890" },
          "punctuation.bracket":    { "color": "#625e56" },
          "punctuation.delimiter":  { "color": "#9c9890" },
          "punctuation.list_marker": { "color": "#9b782c" },
          "punctuation.special":    { "color": "#9b782c" },
          "string":                 { "color": "#636e1c" },
          "string.escape":          { "color": "#9b782c" },
          "string.regex":           { "color": "#636e1c" },
          "string.special":         { "color": "#9b782c" },
          "string.special.symbol":  { "color": "#8f3b00" },
          "tag":                    { "color": "#3b3628", "font_weight": 700 },
          "text.literal":           { "color": "#8f3b00" },
          "title":                  { "color": "#3b3628", "font_weight": 700 },
          "type":                   { "color": "#00664e", "font_weight": 700 },
          "variable":               { "color": "#1c1b1a" },
          "variable.special":       { "color": "#8f3b00", "font_style": "italic" },
          "variant":                { "color": "#8f3b00", "font_weight": 700 }
        }
      }
    }
  ]
}
