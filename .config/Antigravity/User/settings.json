{
  "workbench.colorTheme": "AtlasAta - Caelestia Light",
  "terminal.external.linuxExec": "fish",
  "security.workspace.trust.untrustedFiles": "open",
  "antigravity.marketplaceGalleryItemURL": "https://marketplace.visualstudio.com/items",
  "editor.fontVariations": true,
  "window.zoomLevel": 2,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "explorer.confirmDragAndDrop": false,
  "editor.minimap.enabled": false,
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.CustomBrowser": "firefox",
  "workbench.externalBrowser": "firefox",
  "editor.defaultFormatter": null,
  "python.languageServer": "Pylance",
  "redhat.telemetry.enabled": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.fontFamily": "'Anthropic Mono Variable', 'monospace', monospace",
  "workbench.sideBar.location": "right",
  "window.menuBarVisibility": "compact",
  "workbench.activityBar.location": "hidden",
  "workbench.auxiliaryActivityBar.location": "default",
  "workbench.statusBar.visible": false,
  "files.hotExit": "onExitAndWindowClose",
  "workbench.editor.centeredLayoutAutoResize": false,
  "workbench.startupEditor": "terminal",
  "window.menuStyle": "native",
  "files.autoSave": "afterDelay",
  "window.restoreWindows": "preserve",
  "window.newWindowDimensions": "inherit",
  "window.newWindowProfile": "Default",
  "workbench.layoutControl.type": "toggles",
  "workbench.layoutControl.enabled": true,
  "workbench.editor.restoreViewState": true,
  "prettier.bracketSpacing": true,
  "java.help.showReleaseNotes": false,
  "terminal.integrated.hideOnStartup": "whenEmpty",
  "extensions.experimental.deferredStartupFinishedActivation": true,
  "terminal.integrated.defaultProfile.linux": "fish",
  "workbench.editor.highlightModifiedTabs": true,
  "terminal.integrated.fontFamily": "JetbrainsMono Nerd Font, 'monospace'",
  "terminal.integrated.fontLigatures.enabled": true,
  "workbench.quickOpen.preserveInput": true,
  "workbench.commandPalette.preserveInput": true,
  "workbench.editor.sharedViewState": true,
  "search.quickAccess.preserveInput": true,
  "window.titleSeparator": " — ",
  "terminal.integrated.enablePersistentSessions": false,
  "workbench.editorAssociations": {
    "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
    "*.qrc": "qt-core.qrcEditor",
  },
  "qt-core.additionalQtPaths": [
    {
      "name": "Qt-5.15.18-linux-g++_from_PATH",
      "path": "/usr/bin/qmake",
    },
  ],
  "editor.codeActionsOnSave": {
  
    "source.fixAll": "always",
    "source.addMissingImports": "always",
    "source.organizeImports": "always",
    "source.sortImports": "always",
  },
  "typescript.preferences.importModuleSpecifier": "project-relative",
  "typescript.preferences.importModuleSpecifierEnding": "index",
  "typescript.updateImportsOnFileMove.enabled": "always",
}
