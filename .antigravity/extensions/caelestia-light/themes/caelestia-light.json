    "peekViewTitleDescription.foreground":  "#7b776d",

    "breadcrumb.foreground":                "#7b776d",
    "breadcrumb.focusForeground":           "#1c1b1a",
    "breadcrumb.activeSelectionForeground": "#3b3628",
    "breadcrumbPicker.background":          "#f7f3f0",

    "menu.background":                      "#fdf8f5",
    "menu.foreground":                      "#1c1b1a",
    "menu.selectionBackground":             "#e8e2d7",
    "menu.selectionForeground":             "#1c1b1a",
    "menu.separatorBackground":             "#e6e2df",
    "menubar.selectionBackground":          "#e8e2d7",
    "menubar.selectionForeground":          "#1c1b1a",

    "settings.headerForeground":            "#3b3628",
    "settings.modifiedItemIndicator":       "#9b782c",
    "settings.focusedRowBackground":        "#f2edea",
    "settings.rowHoverBackground":          "#f7f3f0"
  },

  "semanticTokenColors": {
    "keyword":              { "foreground": "#3b3628", "bold": true },
    "variable":             "#1c1b1a",
    "variable.readonly":    "#4a473e",
    "parameter":            "#4a473e",
    "function":             "#4b882e",
    "method":               "#4b882e",
    "type":                 "#00664e",
    "class":                "#00664e",
    "interface":            "#636e1c",
    "enum":                 "#00664e",
    "enumMember":           "#8f3b00",
    "property":             "#4a473e",
    "namespace":            "#625e56",
    "string":               "#636e1c",
    "number":               "#9b782c",
    "operator":             "#625e56",
    "comment":              { "foreground": "#7b776d", "italic": true },
    "decorator":            "#9b782c",
    "macro":                "#8f3b00"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7b776d", "fontStyle": "italic" }
    },
    {
      "name": "Keywords & Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.other.important",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#3b3628", "fontStyle": "bold" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.assignment"
      ],
      "settings": { "foreground": "#625e56" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": { "foreground": "#636e1c" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#9b782c" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#9b782c" }
    },
    {
      "name": "Boolean & Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#8f3b00", "fontStyle": "italic" }
    },
    {
      "name": "Constants",
      "scope": ["constant.language", "constant.other", "variable.other.constant"],
      "settings": { "foreground": "#8f3b00" }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": { "foreground": "#4b882e" }
    },
    {
      "name": "Types, Classes & Interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#00664e" }
    },
    {
      "name": "Interfaces & Enums",
      "scope": ["entity.name.interface", "entity.name.enum"],
      "settings": { "foreground": "#636e1c" }
    },
    {
      "name": "Enum members",
      "scope": ["variable.other.enummember", "constant.other.enum"],
      "settings": { "foreground": "#8f3b00" }
    },
    {
      "name": "Variables & Parameters",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": { "foreground": "#1c1b1a" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "variable.other.object.property"
      ],
      "settings": { "foreground": "#4a473e" }
    },
    {
      "name": "Namespaces & Modules",
      "scope": ["entity.name.namespace", "entity.name.module", "support.module"],
      "settings": { "foreground": "#625e56" }
    },
    {
      "name": "Decorators & Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation"
      ],
      "settings": { "foreground": "#9b782c" }
    },
    {
      "name": "Import / Export",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": { "foreground": "#3b3628", "fontStyle": "bold" }
    },

    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": { "foreground": "#3b3628" }
    },
    {
      "name": "HTML/JSX Attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": { "foreground": "#9a7a00" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#00664e" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#4b882e" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css", "meta.property-value"],
      "settings": { "foreground": "#636e1c" }
    },
    {
      "name": "CSS Units & Numbers",
      "scope": ["constant.numeric.css", "keyword.other.unit.css"],
      "settings": { "foreground": "#9b782c" }
    },

    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": { "foreground": "#9c9890" }
    },
    {
      "name": "Brackets & Parens",
      "scope": [
        "punctuation.definition.block",
        "punctuation.section.block",
        "meta.embedded"
      ],
      "settings": { "foreground": "#7b776d" }
    },

    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#3b3628", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#1c1b1a", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#4a473e", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#8f3b00" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#00664e" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#7b776d", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullets",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#9b782c" }
    },

    {
      "name": "Git diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#4f6354" }
    },
    {
      "name": "Git diff removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ba1a1a" }
    },
    {
      "name": "Git diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#9b782c" }
    },

    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#4b882e" }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml", "support.type.property-name.yaml"],
      "settings": { "foreground": "#3b3628" }
    },
    {
      "name": "TOML keys",
      "scope": ["support.type.property-name.toml", "entity.other.attribute-name.toml"],
      "settings": { "foreground": "#3b3628" }
    },

    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#ba1a1a", "fontStyle": "underline" }
    }
  ]
}
